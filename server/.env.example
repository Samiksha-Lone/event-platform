# Server Configuration
PORT=3000
NODE_ENV=development

# Database - MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/event-platform

# JWT Authentication Secret (change this in production!)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Frontend URL (for CORS configuration)
CLIENT_URL=http://localhost:5173

# Email Configuration - Gmail with App Password
# Instructions: https://support.google.com/accounts/answer/185833
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password

# ImageKit Configuration (free tier: https://imagekit.io/signup)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint

# Optional
DEBUG=false
